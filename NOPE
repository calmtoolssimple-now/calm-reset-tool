<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Calm Reset Tool – Free Stress Relief Plan for Anxiety & Overwhelm</title>
  <meta name="description" content="Feeling anxious, overwhelmed, or foggy? Get a free personalized calm-down plan in 60 seconds. Choose your stress level, time available, and location — and reset." />
  <meta name="keywords" content="calm reset tool, stress relief, anxiety relief, how to calm down, overwhelmed what to do, free mindfulness tool, stress management, calm plan, anxiety tool, breathing exercise, reset anxiety, calm down fast, mental reset, stress relief for women" />
  <meta name="author" content="Calm and Simple" />
  <meta name="robots" content="index, follow" />

  <link rel="canonical" href="https://calmtoolssimple-now.github.io/calm-reset-tool/" />

  <style>
    * { box-sizing: border-box; }
    body { font-family: Arial, sans-serif; background: #f6f1ec; margin: 0; }
    .container { max-width: 760px; margin: auto; padding: 20px; }
    .card { background: white; padding: 20px; border-radius: 12px; }
    button { width: 100%; padding: 12px; margin-top: 15px; }
  </style>
</head>
<body>

<div class="container">
  <div class="card">
    <h2>Calm Reset Tool</h2>

    <label>How do you feel?</label>
    <select id="feeling">
      <option>Anxious</option>
      <option>Overwhelmed</option>
      <option>Tired</option>
      <option>Irritable</option>
      <option>Foggy</option>
    </select>

    <button onclick="generateCalm()">Get My Calm Plan</button>

    <div id="result"></div>

    <input type="email" id="userEmail" placeholder="Enter your email">
    <button onclick="sendEmail()">Send My Plan</button>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script>
emailjs.init("8-6yk8giaQBxBAjNz");

function generateCalm() {
  document.getElementById("result").innerText = "Take a breath and reset.";
}

function sendEmail() {
  const email = document.getElementById("userEmail").value;
  const resultText = document.getElementById("result").innerText;

  emailjs.send("service_hfr86fp", "template_80hmaqd", {
    user_email: email,
    message: resultText
  }).then(() => alert("Sent!"));
}
</script>

</body>
</html>
